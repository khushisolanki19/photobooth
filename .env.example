# Supabase (required for multi-device collaborative rooms)
# Create a project at https://supabase.com then paste values below.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Never commit service-role keys. The anon key is safe for the browser
# when paired with the RLS policies in supabase/schema.sql.
